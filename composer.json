{
   "name": "leandrotijink/embla",
   "version": "1.2.0",
   "description": "A lightweight component library, helping you to build modern interfaces more efficiently.",
   "keywords": ["components", "interface", "php", "laravel", "modern", "web"],
   "homepage": "https://github.com/leandrotijink/embla",
   "authors": [
      {
         "name": "Léandro Tijink"
      }
   ],
   "type": "library",
   "license": "MIT",
   "require": {
      "php-64bit": "^8.5",
      "laravel/framework": "^13.0"
   },
   "autoload": {
      "psr-4": {
         "Rovota\\Embla\\": "src/"
      }
   },
   "extra": {
      "laravel": {
         "providers": [
            "Rovota\\Embla\\EmblaServiceProvider"
         ],
         "aliases": {
            "Tabs": "Rovota\\Embla\\Facades\\Tabs"
         }
      }
   },
   "config": {
      "sort-packages": true,
      "optimize-autoloader": true
   }
}